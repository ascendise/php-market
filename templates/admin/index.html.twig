{% extends 'base.html.twig' %}

{% block styles %}
    <link rel='stylesheet' href="{{ asset('styles/pages/admin.scss') }}" />
{% endblock %}

{% block title %}Market Administration{% endblock %}

{% block body %}

<div class='bots'>
    <div class='list'>
        <h1>Bots</h1>
        <table>
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Type</th>
                    <th>Frequency</th>
                    <th>Args</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
            {% for bot in bots %}
                <tr>
                    <td class='centered'>{{ bot.id }}</td>
                    <td class='centered'>{{ bot.type.name }}</td>
                    <td class='centered'>{{ bot.frequency }}</td>
                    <td>{{ bot.args|json_encode }}</td>
                    <td class='centered'>
                        <button hx-delete='{{ bot.halLinks.self.href }}' hx-target='body'>Delete</button>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
    <div class='editor'>
        <h1>Create New Bot</h1>
        <form hx-post='{{ bots.halLinks.bots.href }}' hx-target='body'>
            <select name='type'>
            {% for type in enum('App\\Application\\Bots\\BotType').cases %}
                <option value='{{ type.value }}'>{{ type.name }}</option>
            {% endfor %}
            </select>
            <input name='frequency' type='time' step=1 value='00:05:00' min='00:00:01' max='24:00:00' required />
            <table id='producer-args'>
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Trading Volume</th>
                        <th>Offer Quantity</th>
                        <th>Price Per Item</th>
                        <th>Options</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class='centered'>
                            <input type='text' name='args[produceRates][0][product][name]' required/>
                        </td>
                        <td class='centered'>
                            <input type='text' pattern='^\d+(-\d+)?$' name='args[produceRates][0][tradingVolume]' required/>
                        </td>
                        <td class='centered'>
                            <input type='text' pattern='^\d+(-\d+)?$' name='args[produceRates][0][offerQuantity]' required/>
                        </td>
                        <td class='centered'>
                            <input type='text' pattern='^\d+(-\d+)?$' name='args[produceRates][0][pricePerItem]' required/>
                        </td>
                        <td class='centered'>
                            <button onclick="deleteRow('producer-args', this)" type='button'>Delete Row</button>
                        </td>
                    </tr>
                </tbody>
            </table>
            <button type='button' onclick="newRow('producer-args')">Add Row</button>
            <button>Create Bot</button>
        </form>
    </div>
</div>

{% endblock %}

{% block javascript %}
<script>
    function newRow(tableId) {
        const table = document.getElementById(tableId);
        const templateRow = table.rows[1];
        const newRow = table.insertRow(-1);
        for (const cell of templateRow.cells) {
            const newCell = newRow.insertCell(-1);
            Array.from(cell.attributes).forEach(
                node => newCell.setAttributeNode(node.cloneNode(true))
            );
            newCell.innerHTML = cell.innerHTML;
        }
        updateArgsIndex(table);
    }

    function deleteRow(tableId, childElement) {
        const table = document.getElementById(tableId);
        const rows = Array.from(table.rows).slice(1); //Ignore Header Row
        if(rows.length <= 1) {
            console.log('Tried to delete last row, which is required for cloning');
            return;
        }
        const row = rows.filter(r => r.contains(childElement));
        if(row[0]) {
            row[0].remove();
        }
        updateArgsIndex(table);
    }

    function updateArgsIndex(table) {
        let index = 0;
        for(const row of table.rows) {
            const inputs = row.getElementsByTagName('input');
            for(const input of inputs) {
                const name = input.attributes['name'].nodeValue;
                const newName = name.replace(/\d+/gm, index);
                input.attributes['name'].nodeValue = newName;
            }
            index++;
        }

    }
</script>
{% endblock %}
